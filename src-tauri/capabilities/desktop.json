{
    "identifier": "desktop-capability",
    "platforms": ["windows", "linux"],
    "windows": ["main", "recording_overlay"],
    "permissions": [
        "core:default",
        "core:event:default",
        "dialog:allow-open",
        "dialog:allow-save",
        "clipboard-manager:allow-read-text",
        "clipboard-manager:allow-write-text",
        "opener:default",
        "autostart:default",
        "updater:default",
        "process:default",
        "store:default"
    ]
}
